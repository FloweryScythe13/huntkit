# huntkit environment variables
# Copy this file to .env and fill in your keys.
# Then run: bash setup-env.sh
# .env is gitignored — never commit it.

# ---------------------------------------------------------------------------
# Required for MCP servers
# ---------------------------------------------------------------------------

# Companies House Public Data API (org-intel MCP server)
# Free key: https://developer.company-information.service.gov.uk
CH_API_KEY=

# VirusTotal (threat-intel MCP server)
# Free key (500 req/day): https://virustotal.com/gui/join-us
VT_API_KEY=

# abuse.ch — covers URLhaus + ThreatFox (threat-intel MCP server)
# Free key: https://auth.abuse.ch
ABUSE_CH_AUTH_KEY=

# ---------------------------------------------------------------------------
# Optional: search & scrape APIs (skill degrades gracefully without these)
# Run bash skills/osint/scripts/diagnose.sh to see what's active.
# ---------------------------------------------------------------------------

# Perplexity Sonar / Deep — AI-powered search with citations
# https://perplexity.ai
PERPLEXITY_API_KEY=

# Apify — LinkedIn, Instagram, TikTok, YouTube, Facebook scrapers
# https://apify.com (free tier available)
APIFY_TOKEN=

# Jina — reader + deepsearch
# https://jina.ai (free tier available)
JINA_API_KEY=

# Parallel AI — social media search with cross-referencing
# https://parallel.ai
PARALLEL_API_KEY=

# Exa — semantic search
# https://exa.ai
EXA_API_KEY=

# Tavily — agent-optimised search
# https://tavily.com
TAVILY_API_KEY=

# Bright Data MCP URL — bypasses bot detection, Facebook, LinkedIn authwall
# https://brightdata.com
BRIGHTDATA_MCP_URL=
